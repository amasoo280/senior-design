# ==================================
# Sargon Partners AI Chatbot - Backend
# ==================================

# Database
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_MAX_RESULT_ROWS=500

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-3-sonnet-20240229-v1:0

# Auth0
# Get these from Auth0 Dashboard > Applications > Your App
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin emails (comma-separated, optional)
ADMIN_EMAILS=admin@example.com

# Tenant ID
DEFAULT_TENANT_ID=your_tenant_id

# Allowed tenant IDs (comma-separated UUIDs). Required — no tenant can query without being listed here.
ALLOWED_TENANT_IDS=uuid1,uuid2

# Auth0 - Get these from Auth0 Dashboard > Applications > Your App
VITE_AUTH0_DOMAIN=dev-10gby1gtpnklox0e.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id
# Optional: must match APIs > Identifier in Auth0. Leave unset if you see "Service not found" until the API is created.
# VITE_AUTH0_AUDIENCE=http://localhost:8000

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# "Show SQL" in chat: omit for default (on in `npm run dev`, off in production builds). Set VITE_SHOW_SQL=true|false to override.
# VITE_SHOW_SQL=false

# Tenant ID
VITE_DEFAULT_TENANT_ID=your_tenant_id
